@model List<ApplicationDto>
@{
    ViewData["Title"] = "Applications";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2 class="mb-0"><i class="bi bi-grid me-2"></i>Applications</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Application
    </a>
</div>

<div class="row g-3">
    @foreach (var app in Model)
    {
        <div class="col-md-4">
            <div class="card app-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <span class="app-icon"><i class="bi bi-app"></i></span>
                        <div class="flex-grow-1">
                            <h5 class="card-title mb-0">@app.AppName</h5>
                            <small class="text-muted">ID: @app.AppId</small>
                        </div>
                        <a asp-action="Edit" asp-route-id="@app.AppId" class="btn btn-sm btn-outline-secondary" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </div>
                    <p class="card-text mt-3 text-muted small mb-0">@(app.Description ?? "No description provided")</p>
                </div>
                <div class="card-footer text-muted small d-flex align-items-center">
                    <i class="bi bi-calendar3 me-1"></i> Created: @app.CreatedAt.ToString("MMM dd, yyyy")
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="bi bi-grid empty-state-icon d-block mb-2"></i>
                    <p class="text-muted mb-3">No applications found.</p>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>Create your first application
                    </a>
                </div>
            </div>
        </div>
    }
</div>
