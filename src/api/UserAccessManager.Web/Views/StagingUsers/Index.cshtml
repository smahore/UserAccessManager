@model PagedResult<StagingUserDto>
@{
    ViewData["Title"] = "Staging Users";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2 class="mb-0"><i class="bi bi-person-plus me-2"></i>Staging Users</h2>
    <span class="badge bg-info fs-6 rounded-pill">@Model.TotalCount pending</span>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>User</th>
                        <th>Email</th>
                        <th>Source</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Items)
                    {
                        <tr>
                            <td class="text-muted">@user.UserId</td>
                            <td>
                                <strong>@user.UserName</strong>
                                <div class="text-muted small">@(user.FullName ?? "—")</div>
                            </td>
                            <td class="small">@(user.Email ?? "—")</td>
                            <td><span class="badge badge-source">@(user.Source ?? "—")</span></td>
                            <td class="text-end">
                                <form asp-action="Promote" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.UserId" />
                                    <button type="submit" class="btn btn-sm btn-success"
                                            onclick="return confirm('Promote this user to a full user account?')">
                                        <i class="bi bi-arrow-up-circle me-1"></i>Promote
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-check-circle empty-state-icon d-block mb-2"></i>
                                No staging users to review
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
