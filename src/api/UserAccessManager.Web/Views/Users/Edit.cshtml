@model UpdateUserRequest
@{
    ViewData["Title"] = "Edit User";
    var userId = (int)ViewBag.UserId;
    var userName = ViewBag.UserName as string;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Details" asp-route-id="@userId" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit User: @userName</h2>
        </div>

        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@userId" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Source" class="form-label">Source</label>
                        <select asp-for="Source" class="form-select">
                            <option value="">No change</option>
                            <option value="Manual">Manual</option>
                            <option value="AD">AD</option>
                            <option value="LDAP">LDAP</option>
                        </select>
                        <span asp-validation-for="Source" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UpdatedBy" class="form-label">Updated By</label>
                        <input asp-for="UpdatedBy" class="form-control" placeholder="Optional" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@userId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
