@model CreateUserRequest
@{
    ViewData["Title"] = "Create User";
    var stagingUsers = ViewBag.StagingUsers as List<StagingUserDto> ?? new List<StagingUserDto>();
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="page-header d-flex align-items-center">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0"><i class="bi bi-person-plus me-2"></i>Add User</h2>
        </div>

        @if (stagingUsers.Any())
        {
            <div class="card mb-3">
                <div class="card-body">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-person-check me-1 text-info"></i>Populate from Staging User
                    </label>
                    <select id="stagingUserSelect" class="form-select">
                        <option value="">— Select a staging user to auto-fill —</option>
                        @foreach (var su in stagingUsers)
                        {
                            <option value="@su.UserId"
                                    data-username="@su.UserName"
                                    data-fullname="@su.FullName"
                                    data-email="@su.Email"
                                    data-source="@su.Source">
                                @su.UserName — @(su.Email ?? su.FullName ?? "No email")
                            </option>
                        }
                    </select>
                    <small class="text-muted">These are users not yet in the main Users list.</small>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">Username <span class="text-danger">*</span></label>
                        <input asp-for="UserName" class="form-control" id="inputUserName" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" id="inputFullName" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" id="inputEmail" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Source" class="form-label">Source <span class="text-danger">*</span></label>
                        <select asp-for="Source" class="form-select" id="inputSource">
                            <option value="">Select source...</option>
                            <option value="Manual">Manual</option>
                            <option value="SAP">SAP</option>
                            <option value="AD">AD</option>
                            <option value="LDAP">LDAP</option>
                        </select>
                        <span asp-validation-for="Source" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreatedBy" class="form-label">Created By</label>
                        <input asp-for="CreatedBy" class="form-control" placeholder="Optional" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Create User
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('stagingUserSelect')?.addEventListener('change', function () {
            const opt = this.options[this.selectedIndex];
            if (!opt.value) return;
            document.getElementById('inputUserName').value = opt.dataset.username || '';
            document.getElementById('inputFullName').value = opt.dataset.fullname || '';
            document.getElementById('inputEmail').value = opt.dataset.email || '';
            const source = (opt.dataset.source || '').trim();
            const srcSelect = document.getElementById('inputSource');
            for (let i = 0; i < srcSelect.options.length; i++) {
                if (srcSelect.options[i].value.toLowerCase() === source.toLowerCase()) {
                    srcSelect.selectedIndex = i;
                    break;
                }
            }
        });
    </script>
}
