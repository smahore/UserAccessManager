@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="display-4 text-danger"><i class="bi bi-exclamation-triangle"></i></h1>
    <h2>An error occurred.</h2>
    <p class="text-muted">@(Model.Message ?? "An unexpected error occurred while processing your request.")</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
        <i class="bi bi-house me-1"></i>Back to Dashboard
    </a>
</div>
