@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header d-flex align-items-center">
    <h2 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon stat-icon-primary mx-auto mb-2"><i class="bi bi-people"></i></div>
                <div class="stat-value">@Model.TotalUsers</div>
                <small class="text-muted">Total Users</small>
            </div>
            <a asp-controller="Users" asp-action="Index" class="card-footer text-center text-decoration-none small">
                View Users <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon stat-icon-success mx-auto mb-2"><i class="bi bi-grid"></i></div>
                <div class="stat-value">@Model.TotalApplications</div>
                <small class="text-muted">Applications</small>
            </div>
            <a asp-controller="Applications" asp-action="Index" class="card-footer text-center text-decoration-none small">
                View Applications <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon stat-icon-warning mx-auto mb-2"><i class="bi bi-clipboard-check"></i></div>
                <div class="stat-value">@Model.PendingRequests</div>
                <small class="text-muted">Pending Requests</small>
            </div>
            <a asp-controller="AccessRequests" asp-action="Index" asp-route-status="Pending" class="card-footer text-center text-decoration-none small">
                View Pending <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body text-center py-4">
                <div class="stat-icon stat-icon-info mx-auto mb-2"><i class="bi bi-person-plus"></i></div>
                <div class="stat-value">@Model.StagingUsers</div>
                <small class="text-muted">Staging Users</small>
            </div>
            <a asp-controller="StagingUsers" asp-action="Index" class="card-footer text-center text-decoration-none small">
                View Staging <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Access Requests</h5>
        <a asp-controller="AccessRequests" asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Request
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>User</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model.RecentRequests)
                    {
                        <tr>
                            <td class="text-muted">#@req.AccessRequestId</td>
                            <td><strong>@req.UserName</strong></td>
                            <td><code>@req.RoleName</code></td>
                            <td>
                                <span class="badge badge-status-@req.Status.ToLower()">@req.Status</span>
                            </td>
                            <td class="text-muted">@req.CreatedDate.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                    @if (!Model.RecentRequests.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-inbox empty-state-icon d-block mb-2"></i>No recent requests
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
