@model PagedResult<AccessRequestDto>
@{
    ViewData["Title"] = "Access Requests";
    var statusFilter = ViewBag.StatusFilter as string;
    var statuses = new[] { "Pending", "Approved", "Rejected", "Cancelled", "Fulfilled" };
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>Access Requests</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Request
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Index" class="btn btn-sm filter-pill @(string.IsNullOrEmpty(statusFilter) ? "btn-primary" : "btn-outline-primary")">
                All
            </a>
            @foreach (var s in statuses)
            {
                <a asp-action="Index" asp-route-status="@s"
                   class="btn btn-sm filter-pill @(statusFilter == s ? "btn-primary" : "btn-outline-primary")">
                    @s
                </a>
            }
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model.Items)
                    {
                        <tr>
                            <td class="text-muted">#@req.AccessRequestId</td>
                            <td><strong>@req.UserName</strong></td>
                            <td class="small">@(req.Email ?? "—")</td>
                            <td><code>@req.RoleName</code></td>
                            <td>
                                <span class="badge badge-status-@req.Status.ToLower()">@req.Status</span>
                            </td>
                            <td class="text-muted small">@req.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (req.Status == "Pending")
                                {
                                    <div class="btn-group btn-group-sm">
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@req.AccessRequestId" />
                                            <input type="hidden" name="status" value="Approved" />
                                            <button type="submit" class="btn btn-outline-success" title="Approve">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@req.AccessRequestId" />
                                            <input type="hidden" name="status" value="Rejected" />
                                            <button type="submit" class="btn btn-outline-danger" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                                @if (req.Status == "Approved")
                                {
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@req.AccessRequestId" />
                                        <input type="hidden" name="status" value="Fulfilled" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary" title="Fulfill">
                                            <i class="bi bi-check-all me-1"></i>Fulfill
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-clipboard empty-state-icon d-block mb-2"></i>No access requests found
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-status="@statusFilter">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-status="@statusFilter">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-status="@statusFilter">Next</a>
            </li>
        </ul>
    </nav>
}

<p class="text-muted text-center small mt-2">
    Showing page @Model.Page of @Model.TotalPages (@Model.TotalCount total requests)
</p>
